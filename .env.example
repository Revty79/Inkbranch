# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth scaffolding (to be wired in next prompt)
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Database connection used by Drizzle migrations/schema
# If your password has special characters (like @), URL-encode them.
DATABASE_URL=postgresql://inkbranch_app:Darkness1%40@localhost:5432/inkbranch_dev

# Runtime storage backend
INKBRANCH_STORAGE_MODE=postgres

# AI scene runtime (local only)
# seeded: deterministic local fallback
# ollama: local Ollama /api/chat generation
INKBRANCH_AI_MODE=ollama
# quality: richer output and stricter validation
# speed: lower latency defaults for local iteration
INKBRANCH_RUNTIME_PROFILE=quality
# ai: use Ollama for runtime branch-choice generation
# seeded_fast: deterministic fast branch choices (no Ollama branch call)
INKBRANCH_BRANCH_GENERATION_MODE=ai
# eager: rewrite structured projection tables on each mutation
# runtime_only: only persist story_runtime_state on write (run `npm run story:resync` manually)
INKBRANCH_PROJECTION_SYNC_MODE=eager
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_MS=180000
